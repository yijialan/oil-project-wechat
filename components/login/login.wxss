.weui-half-screen-dialog {
  line-height: 1.4;
  padding: 0 calc(48rpx + env(safe-area-inset-right))
    0 calc(48rpx + env(safe-area-inset-left));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  outline: 0;
  position: relative;
}

.weui-half-screen-dialog::after {
  content: "";
  position: absolute;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(#eceeff 0%, #fff 100%);
  top: 0;
  left: 0;
  z-index: 0;
}

.weui-half-screen-dialog__hd {
  min-height: 128rpx;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.weui-half-screen-dialog__hd__side {
  position: relative;
  left: -16rpx;
}
.weui-half-screen-dialog__title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
}
.weui-half-screen-dialog__bd {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  word-wrap: break-word;
  hyphens: auto;
  padding-bottom: 112rpx;
  font-size: 28rpx;
  color: #b2b2b2;
  position: relative;
  z-index: 2;
}
.weui-half-screen-dialog__desc {
  font-size: 34rpx;
  font-weight: 700;
  color: #b2b2b2;
  line-height: 1.4;
}
.weui-half-screen-dialog__tips {
  font-size: 28rpx;
  color: var(--weui-FG-2);
  line-height: 1.4;
  padding-top: 10rpx;
}
.weui-half-screen-dialog__ft {
  text-align: center;
}
.weui-half-screen-dialog__btn-area {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.weui-btn {
  font-size: 30rpx;
}


.wxButton{
	border-radius: var(--button-round-border-radius,999px);
	color: #fff;
    background: #224BFC;
	border-color: #224BFC;
	font-size: var(--button-normal-font-size,14px);
	height: var(--button-default-height,44px);
	line-height: var(--button-default-height,44px);
}

.weui-half-screen-dialog__ft_disagree{
	/* color: #BDBBBB; */
	font-size: 25rpx;
	padding: 30rpx;
	margin: 0;
	background-color: transparent;
	border: none;
}

.weui-half-screen-dialog__ft_disagree::after{
	border: none;
}


.mask{
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background-color: transparent;
	z-index: 99;
}