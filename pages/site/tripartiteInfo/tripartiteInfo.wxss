.activesList_li_right_options_left{
    color: #FF6107;
    font-size: 21rpx;
    font-weight: bold;
}

.activesList_li_right_options_left text{
    font-size: 44rpx;
    font-family: Arial;
}

.activesList_li_right_options_right{
    width: 142rpx;
}

