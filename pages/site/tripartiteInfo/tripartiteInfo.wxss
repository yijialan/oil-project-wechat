page {
  background: #f4f5f6;
}

.tripartiteInfo {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

image {
  width: auto;
  height: auto;
}

.tripartiteInfo_head {
  position: relative;
  z-index: 0;
  transition: all 0.3s;
}

swiper {
  width: 100%;
  height: 360rpx;
}

swiper image {
  width: 100%;
  height: 100%;
}

.tripartiteInfo_head_shareBox {
  font-size: 23rpx;
  text-align: center;
  background-color: transparent;
  padding: 0;
  margin: 0;
  line-height: 2;
}

.tripartiteInfo_head_shareBox::after {
  border: none;
}

.tripartiteInfo_head_shareBox image {
  width: 45rpx;
  display: block;
  margin: auto;
}

.tripartiteInfo_view {
  background-color: #ffffff;
  border-radius: 13rpx;
  padding: 30rpx;
  margin: 30rpx;
  position: relative;
}

.tripartiteInfo_info_head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tripartiteInfo_info_head_left {
  flex: 1;
  margin-right: 10rpx;
  width: 0;
}

.tripartiteInfo_info_head_left_name {
  color: #262626;
  font-weight: bold;
  font-size: 33rpx;
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tripartiteInfo_info_head_left_address {
  color: #585858;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: break-all;
}

.tripartiteInfo_info_head_left_juli {
  color: #b0b0b0;
  font-size: 24rpx;
}

.tripartiteInfo_info_head_right {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 130rpx;
}

.tripartiteInfo_info_head_right_head {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 20rpx;
}

.tripartiteInfo_info_head_right_head image {
  width: 18rpx;
  margin-right: 2rpx;
}

.tripartiteInfo_info_priceList {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-row-gap: 10rpx;
  grid-column-gap: 10rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  text-align: center;
  color: #a0a0a0;
}

.tripartiteInfo_info_priceList_view text:nth-of-type(2) {
  font-size: 40rpx;
  font-family: Arial, Helvetica, sans-serif;
  letter-spacing: 0;
  font-weight: bold;
}

.tripartiteInfo_info_priceList_view text:last-of-type {
}

.tripartiteInfo_info_priceList_orange text {
  color: #ff9518;
}

.tripartiteInfo_info_priceList_red text {
  color: #ff3333;
}

.tripartiteInfo_info_priceList_blue text {
  color: #374ef5;
}

.tripartiteInfo_info_footer {
  display: flex;
}

.tripartiteInfo_info_footer > view {
  font-size: 21rpx;
  padding: 10rpx;
  border-radius: 5rpx;
  margin-right: 25rpx;
  width: 180rpx;
  max-width: 180rpx;
  display: flex;
  align-items: center;
}

.tripartiteInfo_info_footer > view:last-of-type {
  margin-right: 0;
}

.tripartiteInfo_info_footer > view image {
  width: 18rpx;
  margin-right: 6rpx;
}

.tripartiteInfo_info_footer > view view {
  flex: 1;
  width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tripartiteInfo_info_footer_blue {
  background-color: #f6f6fb;
  color: #374ef5;
  white-space: nowrap;
  width: fit-content !important;
}

.tripartiteInfo_info_footer_orange {
  background-color: #fff4f2;
  color: #ff704f;
}

.tripartiteInfo_view_li {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 30rpx 0;
}

.tripartiteInfo_view_li_left {
  font-size: 27rpx;
  font-weight: bold;
}

.tripartiteInfo_view_li_type {
  color: #b0b0b0;
  font-size: 25rpx;
}

.optionPopup_li_tagList {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-row-gap: 20rpx;
  grid-column-gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 30rpx 30rpx 0;
}

.optionPopup_li_tag {
  background-color: #f8f8f8;
  font-size: 25rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 60rpx;
  text-align: center;
  border: 1rpx solid #f8f8f8;
}

.tripartiteInfo_view_li_pay {
  display: flex;
}
.tripartiteInfo_view_li_pay > view {
  height: 51rpx;
  background: #e8e9f4;
  border-radius: 7rpx;
  line-height: 51rpx;
  font-size: 23rpx;
  text-align: center;
  color: #4456fd;
  padding: 0 10rpx;
}

.tripartiteInfo_view_li_pay > view:first-of-type {
  color: #47ac45;
  background: #ebf8ef;
  margin-right: 20rpx;
}

.tripartiteInfo_introduce_head {
  color: #262626;
  font-size: 31rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.tripartiteInfo_introduce_head text {
  color: #c2c2c2;
}

.tripartiteInfo_introduce_footer {
  color: #c3c3c3;
  font-size: 24rpx;
}

.tripartiteInfo_footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom) * 0.5);
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
}

swiper .wx-swiper-dot {
  border-radius: 50%;
  width: 24rpx;
  height: 5rpx;
  background: rgba(255, 255, 255, 0.29);
  border-radius: 5rpx;
  margin-bottom: 0;
  transition: all 0.5s;
}

swiper .wx-swiper-dot-active {
  background: #fff;
}

.popup {
 
}

.popup_li {
  background-color: #fff4f2;
  color: #ff704f;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  padding: 10rpx;
}
.popup_li image {
  width: 18rpx;
  margin-right: 6rpx;
}

.popup_li_blue {
  background-color: #f6f6fb;
  color: #374ef5;
  white-space: nowrap;
  width: fit-content !important;
}

.popup_li view {
  display: inline;
}

.popup_head {
  text-align: center;
  font-size: 33rpx;
  padding: 38rpx;
  position: sticky;
  top: 0;
  background-color: #ffffff;
  z-index: 9;
  font-weight: bold;
}

.popup_head_close {
  position: absolute;
  right: 38rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #747474;
}

.activesListBox{
    padding: 30rpx;
    border-radius: 20rpx;
}

.activesList_li{
    display: flex;
	padding: 30rpx;
	background-color: #ffffff;
	border-radius: 13rpx;
	margin-bottom: 20rpx;
	align-items: center;
}

.activesList_li_right{
    flex: 1;
    width: 0;
    margin-left: 38rpx;
    position: relative;
    line-height: 1.5;
}

