@import "/pages/tabbar/tabbar.wxss";

.user-page {
  min-height: 100vh;
  background: #f2f5fb;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.footer-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

.user-hero {
  padding: 32rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #2563eb, #6366f1);
  color: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(37, 99, 235, 0.25);
}

.hero-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  box-sizing: border-box;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
}

.user-sub {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-tag {
  align-self: flex-start;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
  font-size: 22rpx;
}

.user-meta {
  font-size: 24rpx;
  opacity: 0.9;
}

.hero-footer {
  margin-top: 24rpx;
  padding: 20rpx 0 0;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hero-item {
  text-align: center;
}

.hero-value {
  font-size: 28rpx;
  font-weight: 600;
}

.hero-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.8;
}

.hero-divider {
  width: 2rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.3);
}

.stat-cards {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 22rpx 16rpx;
  text-align: center;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
}

.stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.info-panel {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.panel-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.panel-row:last-child {
  border-bottom: none;
}

.row-label {
  font-size: 24rpx;
  color: #64748b;
}

.row-value {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 500;
}
